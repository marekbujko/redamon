# =============================================================================
# RedAmon — Environment Configuration
# =============================================================================
# Copy this file to .env:   cp .env.example .env
#
# AI provider keys (LLM, Tavily) are configured exclusively in the
# Global Settings page (http://localhost:3000/settings) and stored per-user
# in the database. They do NOT belong in this file.
#
# This file contains only infrastructure variables: database credentials,
# port mappings, internal service URLs, scanner config, and tunneling.
# =============================================================================

# ---------------------------------------------------------------------------
# Optional API Keys (infrastructure / scanner use)
# ---------------------------------------------------------------------------
NVD_API_KEY=                    # NIST NVD (higher rate limits for vuln lookups)

# ---------------------------------------------------------------------------
# Tunneling (optional — choose ngrok OR chisel for reverse shell tunneling)
# ---------------------------------------------------------------------------
# Option 1: ngrok (free, no VPS needed, single port only — handler 4444)
NGROK_AUTHTOKEN=                # https://dashboard.ngrok.com/get-started/your-authtoken
                                # Auto-starts with docker compose up if token is set
#
# Option 2: chisel (requires VPS, multi-port — handler 4444 + web delivery 8080)
CHISEL_SERVER_URL=              # e.g. http://your-vps.com:9090 (run: chisel server -p 9090 --reverse)
CHISEL_AUTH=                    # optional user:pass for chisel server authentication
